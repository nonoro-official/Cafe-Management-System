# Runtime environment: development | production | test
NODE_ENV=development

# API server port
PORT=5000

# MongoDB connection string.
# Local dev:       mongodb://127.0.0.1:27017/cafe-management
# Docker Compose:  mongodb://cafe_app:<password>@mongo:27017/cafe-management?authSource=admin
MONGODB_URI=mongodb://127.0.0.1:27017/cafe-management

# Database connection retry (helps when Mongo starts after the API in Compose)
DB_MAX_RETRIES=10
DB_RETRY_DELAY_MS=3000
DB_SERVER_SELECTION_TIMEOUT_MS=5000

# Allowed frontend origins for CORS. Only used in local development; in the
# reverse-proxy deployment everything is same-origin and CORS is not triggered.
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# JSON Web Token settings
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=cms_token

# Auth cookie security. Decoupled from NODE_ENV so the stack can run over plain
# HTTP on an isolated LAN. Set COOKIE_SECURE=true + COOKIE_SAMESITE=none ONLY
# when serving over HTTPS. Browsers reject Secure cookies over HTTP.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Password hashing cost factor
BCRYPT_SALT_ROUNDS=12

# Order pricing (tax as a decimal rate, e.g. 0.12 for 12%)
TAX_RATE=0.12

# Business details printed on receipts
BUSINESS_NAME=Cafe Management System
BUSINESS_ADDRESS=123 Roastery Lane, Bean City
BUSINESS_PHONE=+1 (555) 010-2030
BUSINESS_CURRENCY=USD

# Bootstrap admin account created by `npm run seed`
SEED_ADMIN_NAME=Administrator
SEED_ADMIN_EMAIL=admin@cafe.test
SEED_ADMIN_PASSWORD=Admin123!

# Kiosk identity used to attribute walk-up kiosk orders (created by `npm run seed`)
SEED_KIOSK_NAME=Self-Service Kiosk
SEED_KIOSK_EMAIL=kiosk@cafe.test
SEED_KIOSK_PASSWORD=Kiosk123!
