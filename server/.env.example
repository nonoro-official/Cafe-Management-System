# Runtime environment: development | production | test
NODE_ENV=development

# API server port
PORT=5000

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/cafe-management

# Allowed frontend origins for CORS
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# JSON Web Token settings
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=cms_token

# Password hashing cost factor
BCRYPT_SALT_ROUNDS=12

# Order pricing (tax as a decimal rate, e.g. 0.12 for 12%)
TAX_RATE=0.12

# Business details printed on receipts
BUSINESS_NAME=Cafe Management System
BUSINESS_ADDRESS=123 Roastery Lane, Bean City
BUSINESS_PHONE=+1 (555) 010-2030
BUSINESS_CURRENCY=USD

# Bootstrap admin account created by `npm run seed`
SEED_ADMIN_NAME=Administrator
SEED_ADMIN_EMAIL=admin@cafe.test
SEED_ADMIN_PASSWORD=Admin123!
