# Docker Compose configuration for the isolated-LAN deployment.
# Copy this file to `.env` and set strong values before `docker compose up -d`.
# `.env` is git-ignored — never commit real secrets.

# Application database name
MONGO_DB=cafe-management

# MongoDB root (admin) credentials. Used to administer the server and to create
# the least-privilege app user on first startup.
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=change-me-strong-root-password

# Application DB user the API connects as (readWrite on MONGO_DB only).
MONGO_APP_USERNAME=cafe_app
MONGO_APP_PASSWORD=change-me-strong-app-password

# JWT signing secret — generate 64+ random characters, e.g.
#   openssl rand -hex 32
JWT_SECRET=change-me-to-64-plus-random-hex-characters
JWT_EXPIRES_IN=7d

# Auth cookie security. Keep false over plain HTTP on the LAN (browsers reject
# Secure cookies without HTTPS). Only enable behind TLS.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Pricing / business display
TAX_RATE=0.12
BUSINESS_NAME=Cafe Management System
